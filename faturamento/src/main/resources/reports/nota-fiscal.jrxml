<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="nota-fiscal" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<property name="net.sf.jasperreports.bean.field.delimiters" value="."/>

	<parameter name="NOME" class="java.lang.String"/>
	<parameter name="CPF" class="java.lang.String"/>
	<parameter name="LOGRADOURO" class="java.lang.String"/>
	<parameter name="NUMERO" class="java.lang.String"/>
	<parameter name="BAIRRO" class="java.lang.String"/>
	<parameter name="EMAIL" class="java.lang.String"/>
	<parameter name="TELEFONE" class="java.lang.String"/>
	<parameter name="DATA_PEDIDO" class="java.lang.String"/>
	<parameter name="TOTAL_PEDIDO" class="java.math.BigDecimal"/>
	<parameter name="LOGO" class="java.lang.Object"/>

	<field name="codigo" class="java.lang.Long">
		<description><![CDATA[codigo]]></description>
	</field>
	<field name="descricao" class="java.lang.String">
		<description><![CDATA[descricao]]></description>
	</field>
	<field name="quantidade" class="java.lang.Integer">
		<description><![CDATA[quantidade]]></description>
	</field>
	<field name="valorUnitario" class="java.math.BigDecimal">
		<description><![CDATA[valorUnitario]]></description>
	</field>
	<field name="total" class="java.math.BigDecimal">
		<description><![CDATA[total]]></description>
	</field>

	<title height="79" splitType="Stretch">
		<element kind="image" x="180" y="0" width="200" height="79" hImageAlign="Center" vImageAlign="Middle" onErrorType="Blank">
			<expression><![CDATA[$P{LOGO}]]></expression>
		</element>
	</title>

	<pageHeader height="45" splitType="Stretch">
		<element kind="staticText" x="2" y="7" width="550" height="30" fontSize="16.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[NOTA FISCAL]]></text>
			<box>
				<topPen lineWidth="0.25" lineStyle="Solid" lineColor="#000000"/>
				<bottomPen lineWidth="0.25" lineStyle="Solid" lineColor="#000000"/>
			</box>
		</element>
	</pageHeader>

	<columnHeader height="115" splitType="Stretch">
		<element kind="textField" x="60" y="0" width="220" height="20" vTextAlign="Middle">
			<paragraph leftIndent="4"/>
			<expression><![CDATA[$P{NOME}]]></expression>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" x="0" y="0" width="60" height="20" vTextAlign="Middle" bold="true">
			<paragraph leftIndent="4"/>
			<text><![CDATA[Nome:]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" x="280" y="0" width="50" height="20" vTextAlign="Middle" bold="true">
			<paragraph leftIndent="4"/>
			<text><![CDATA[CPF:]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="textField" x="330" y="0" width="222" height="20" vTextAlign="Middle">
			<paragraph leftIndent="4"/>
			<expression><![CDATA[$P{CPF}]]></expression>
			<box><pen lineWidth="0.5"/></box>
		</element>

		<element kind="staticText" x="0" y="20" width="60" height="20" vTextAlign="Middle" bold="true">
			<paragraph leftIndent="4"/>
			<text><![CDATA[Rua:]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="textField" x="60" y="20" width="220" height="20" vTextAlign="Middle">
			<paragraph leftIndent="4"/>
			<expression><![CDATA[$P{LOGRADOURO} + ", " + $P{NUMERO}]]></expression>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" x="280" y="20" width="50" height="20" vTextAlign="Middle" bold="true">
			<paragraph leftIndent="4"/>
			<text><![CDATA[Bairro:]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="textField" x="330" y="20" width="222" height="20" vTextAlign="Middle">
			<paragraph leftIndent="4"/>
			<expression><![CDATA[$P{BAIRRO}]]></expression>
			<box><pen lineWidth="0.5"/></box>
		</element>

		<element kind="staticText" mode="Opaque" x="0" y="95" width="80" height="20" backcolor="#E6E6E6" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Código]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" mode="Opaque" x="80" y="95" width="260" height="20" backcolor="#E6E6E6" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Descrição]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" mode="Opaque" x="340" y="95" width="50" height="20" backcolor="#E6E6E6" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[QTD]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" mode="Opaque" x="390" y="95" width="85" height="20" backcolor="#E6E6E6" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Unitário]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
		<element kind="staticText" mode="Opaque" x="475" y="95" width="80" height="20" backcolor="#E6E6E6" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Total]]></text>
			<box><pen lineWidth="0.5"/></box>
		</element>
	</columnHeader>

	<detail>
		<band height="20" splitType="Stretch">
			<element kind="textField" x="0" y="0" width="80" height="20" hTextAlign="Center" vTextAlign="Middle">
				<expression><![CDATA[$F{codigo}]]></expression>
				<box><bottomPen lineWidth="0.5"/></box>
			</element>
			<element kind="textField" x="80" y="0" width="260" height="20" vTextAlign="Middle">
				<paragraph leftIndent="5"/>
				<expression><![CDATA[$F{descricao}]]></expression>
				<box><bottomPen lineWidth="0.5"/></box>
			</element>
			<element kind="textField" x="340" y="0" width="50" height="20" hTextAlign="Center" vTextAlign="Middle">
				<expression><![CDATA[$F{quantidade}]]></expression>
				<box><bottomPen lineWidth="0.5"/></box>
			</element>
			<element kind="textField" x="390" y="0" width="85" height="20" pattern="¤ #,##0.00" hTextAlign="Right" vTextAlign="Middle">
				<paragraph rightIndent="5"/>
				<expression><![CDATA[$F{valorUnitario}]]></expression>
				<box><bottomPen lineWidth="0.5"/></box>
			</element>
			<element kind="textField" x="475" y="0" width="80" height="20" pattern="¤ #,##0.00" hTextAlign="Right" vTextAlign="Middle">
				<paragraph rightIndent="5"/>
				<expression><![CDATA[$F{total}]]></expression>
				<box><bottomPen lineWidth="0.5"/></box>
			</element>
		</band>
	</detail>

	<summary height="50" splitType="Stretch">
		<element kind="staticText" mode="Opaque" x="390" y="10" width="85" height="25" backcolor="#E6E6E6" bold="true" hTextAlign="Right" vTextAlign="Middle">
			<paragraph rightIndent="5"/>
			<text><![CDATA[TOTAL GERAL:]]></text>
		</element>
		<element kind="textField" x="475" y="10" width="80" height="25" pattern="¤ #,##0.00" bold="true" hTextAlign="Right" vTextAlign="Middle">
			<paragraph rightIndent="5"/>
			<expression><![CDATA[$P{TOTAL_PEDIDO}]]></expression>
			<box><pen lineWidth="0.5"/></box>
		</element>
	</summary>

	<pageFooter height="30" splitType="Stretch">
		<element kind="textField" x="400" y="10" width="155" height="20" hTextAlign="Right">
			<expression><![CDATA["Gerado em: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></expression>
		</element>
		<element kind="textField" x="0" y="10" width="100" height="20">
			<expression><![CDATA["Página: " + $V{PAGE_NUMBER}]]></expression>
		</element>
	</pageFooter>
</jasperReport>